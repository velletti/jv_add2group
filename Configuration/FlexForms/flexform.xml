<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <sheetTitle>Configuration</sheetTitle>
                <type>array</type>
                <el>
                    <settings.title>
                        <label>Titel</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.title>
                    <settings.cssClass>
                        <label>Css style classname</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>

                            <itemsProcFunc>JVelletti\JvAdd2group\UserFunc\Flexforms->showCssClasses</itemsProcFunc>

                        </config>
                    </settings.cssClass>
                    <settings.description>
                        <label>Description</label>
                        <config>
                            <type>text</type>
                            <cols>30</cols>
                            <rows>8</rows>
                            <enableRichtext>true</enableRichtext>
                        </config>
                    </settings.description>
                    <settings.button>
                        <label>Button</label>
                        <config>
                            <type>input</type>

                        </config>
                    </settings.button>
                    <settings.mustHaveGroups>
                        <label>mustHaveGroups</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>

                            <foreign_table>fe_groups</foreign_table>
                            <foreign_table_where>ORDER BY fe_groups.title</foreign_table_where>
                            <allowed>fe_groups</allowed>
                            <size>4</size>
                            <minitems>0</minitems>
                            <maxitems>10</maxitems>

                        </config>
                    </settings.mustHaveGroups>
                    <settings.mayNotHaveGroups>
                        <label>mayNotHaveGroup</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <foreign_table>fe_groups</foreign_table>
                            <foreign_table_where>ORDER BY fe_groups.title</foreign_table_where>
                            <allowed>fe_groups</allowed>
                            <size>4</size>
                            <minitems>0</minitems>
                            <maxitems>10</maxitems>

                        </config>
                    </settings.mayNotHaveGroups>
                    <settings.willGetGroups>
                        <label>willGetGroups</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <hideSuggest>false</hideSuggest>
                            <foreign_table>fe_groups</foreign_table>
                            <foreign_table_where>ORDER BY fe_groups.title</foreign_table_where>
                            <allowed>fe_groups</allowed>
                            <size>4</size>
                            <minitems>0</minitems>
                            <maxitems>10</maxitems>

                        </config>
                    </settings.willGetGroups>
                    <settings.willLooseGroups>
                        <label>willLooseGroups</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <hideSuggest>false</hideSuggest>
                            <foreign_table>fe_groups</foreign_table>
                            <foreign_table_where>ORDER BY fe_groups.title</foreign_table_where>
                            <allowed>fe_groups</allowed>
                            <size>4</size>
                            <minitems>0</minitems>
                            <maxitems>10</maxitems>

                        </config>
                    </settings.willLooseGroups>

                    <settings.successMsg>
                        <label>Success Message</label>
                        <config>
                            <type>text</type>
                            <cols>30</cols>
                            <rows>4</rows>

                        </config>
                    </settings.successMsg>

                    <settings.classnames>
                        <label>Class->function, will be called after user pressed button</label>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <itemsProcFunc>JVelletti\JvAdd2group\UserFunc\Flexforms->showClasses</itemsProcFunc>

                            <items>

                            </items>
                            <size>6</size>
                            <minitems>0</minitems>
                            <maxitems>10</maxitems>

                        </config>
                    </settings.classnames>
                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>